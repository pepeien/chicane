{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows",
            "displayName": "Windows",
            "description": "Windows using MinGW inside Docker",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-windows",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "/opt/mingw-toolchain.cmake",
                "CMAKE_BUILD_TYPE": "Release",

                "BUILD_DIR": "${sourceDir}/Bin/Docker-Windows",

                "CHICANE_SHARED": "ON",
                "CHICANE_OPENGL": "ON",
                "CHICANE_VULKAN": "ON"
            }
        },
        {
            "name": "linux",
            "displayName": "Linux",
            "description": "Linux using GCC inside Docker",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build-linux",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",

                "BUILD_DIR": "${sourceDir}/Bin/Docker-Linux",

                "CHICANE_SHARED": "ON",
                "CHICANE_OPENGL": "ON",
                "CHICANE_VULKAN": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Building directly on your host machine",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_DIR": "${sourceDir}/Bin/Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Building directly on your host machine",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_DIR": "${sourceDir}/Bin/Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows",
            "configurePreset": "windows"
        },
        {
            "name": "linux",
            "configurePreset": "linux"
        }
    ]
}
